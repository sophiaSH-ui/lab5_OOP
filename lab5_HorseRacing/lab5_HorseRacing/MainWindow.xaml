<Window x:Class="lab5_HorseRacing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hippodrome Simulator" Height="700" Width="1000" Background="#F4F4F9" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45A049"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D3D3D3"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ModernButton}" x:Key="ActionButton">
            <Setter Property="Background" Value="#2196F3"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E88E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ModernButton}" x:Key="DangerButton">
            <Setter Property="Background" Value="#F44336"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E53935"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowBackground" Value="#FAFAFA"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="White" Margin="10" CornerRadius="10" 
                BorderBrush="#E0E0E0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#AAAAAA" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel Margin="15">
                <TextBlock Text="BETTING PANEL" FontSize="20" FontWeight="Black" Foreground="#333333" Margin="0,0,0,5" TextAlignment="Center"/>
                <Separator Margin="0,0,0,15"/>

                <TextBlock Text="Current Balance:" FontSize="14" Foreground="#666666"/>
                <TextBlock Text="{Binding Balance, StringFormat='{}{0:F2} $'}" FontSize="24" FontWeight="Bold" Foreground="#4CAF50" Margin="0,0,0,20"/>

                <TextBlock Text="Bet Amount:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding BetAmount, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,15" FontSize="14"/>

                <TextBlock Text="Select Horse:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Horses}" SelectedItem="{Binding SelectedHorse}" DisplayMemberPath="Name" Margin="0,0,0,15" Padding="5" FontSize="14"/>

                <Button Content="PLACE BET" Command="{Binding PlaceBetCommand}" Style="{StaticResource ModernButton}" Margin="0,0,0,25" Height="40" FontSize="14"/>

                <TextBlock Text="SETTINGS" FontSize="16" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,5" TextAlignment="Center"/>
                <Separator Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                    <TextBlock Text="Horses:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,15,0"/>
                    <Button Content="-" Command="{Binding RemoveHorseCommand}" Style="{StaticResource DangerButton}" Width="30" Height="30" Padding="0"/>
                    <TextBlock Text="{Binding Horses.Count}" VerticalAlignment="Center" Width="40" TextAlignment="Center" FontWeight="Bold" FontSize="16"/>
                    <Button Content="+" Command="{Binding AddHorseCommand}" Style="{StaticResource ActionButton}" Width="30" Height="30" Padding="0"/>
                </StackPanel>

                <Button Content="START SIMULATION" Click="StartSimulation_Click" Style="{StaticResource ModernButton}" Margin="0,0,0,10" Height="45" FontSize="14"/>
                <Button Content="STOP" Click="StopSimulation_Click" Style="{StaticResource DangerButton}" Margin="0,0,0,10"/>
                <Button Content="NEW RACE" Click="ResetRace_Click" IsEnabled="{Binding CanReset}" Style="{StaticResource ActionButton}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Margin="0,10,10,10" CornerRadius="10" ClipToBounds="True" 
                BorderBrush="#2E7D32" BorderThickness="3">
            <Image x:Name="RenderImage" Stretch="Fill"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="White" Margin="0,0,10,10" CornerRadius="10" 
                BorderBrush="#E0E0E0" BorderThickness="1" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#AAAAAA" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <DataGrid ItemsSource="{Binding Horses}" AutoGenerateColumns="False" CanUserAddRows="False" 
                      IsReadOnly="True" HeadersVisibility="Column" SelectionMode="Single"
                      BorderThickness="0" Margin="1">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Color">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ChangeHorseColorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" 
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Click to change color">
                                    <Rectangle Width="24" Height="24" Stroke="#555" StrokeThickness="1" RadiusX="4" RadiusY="4">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Color="{Binding HorseColor}"/>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Place" Binding="{Binding Place}" Width="0.5*"/>
                    <DataGridTextColumn Header="Horse Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Race Time" Binding="{Binding RaceTime, StringFormat={}{0:mm\\:ss\\.ff}}" Width="*"/>
                    <DataGridTextColumn Header="Coef" Binding="{Binding Coefficient, StringFormat={}{0:F2}}" Width="*"/>
                    <DataGridTextColumn Header="Bet Money" Binding="{Binding MoneyBet, StringFormat={}{0:F2} $}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
