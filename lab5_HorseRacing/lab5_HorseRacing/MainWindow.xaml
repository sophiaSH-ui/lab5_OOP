<Window x:Class="lab5_HorseRacing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Horse Race Simulation" Height="600" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="10">
            <TextBlock Text="Bettings" FontSize="18" FontWeight="Bold" Foreground="Salmon" Margin="0,0,0,20"/>
            <TextBlock Text="{Binding Balance, StringFormat='Balance: {0}$'}" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBox Text="{Binding BetAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <ComboBox ItemsSource="{Binding Horses}" SelectedItem="{Binding SelectedHorse}" DisplayMemberPath="Name" Margin="0,0,0,10"/>

            <Button Content="BET" Command="{Binding PlaceBetCommand}" Margin="0,0,0,20" Width="100" HorizontalAlignment="Left"/>

            <Button Content="START SIMULATION" Click="StartSimulation_Click" Margin="0,0,0,10" Background="LightGreen"/>
            <Button Content="RESET" Command="{Binding ResetRaceCommand}" Margin="0,0,0,10"/>
        </StackPanel>

        <Image x:Name="RenderImage" Grid.Row="0" Grid.Column="1" Stretch="Fill"/>

        <DataGrid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding Horses}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Color">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Rectangle Width="20" Height="20">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="{Binding HorseColor}"/>
                                </Rectangle.Fill>
                            </Rectangle>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Position" Binding="{Binding PositionX, StringFormat={}{0:F0}}"/>
                <DataGridTextColumn Header="Time" Binding="{Binding RaceTime, StringFormat={}{0:mm\\:ss\\.ff}}"/>
                <DataGridTextColumn Header="Coefficient" Binding="{Binding Coefficient}"/>
                <DataGridTextColumn Header="Money" Binding="{Binding MoneyBet}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>