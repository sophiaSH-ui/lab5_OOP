<Window x:Class="lab5_HorseRacing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hippodrome Simulator" Height="740" Width="1140"
        MinHeight="740" MinWidth="1140"
        Background="#0B1410" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Button" x:Key="BaseBtn">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2A1C"/>
                                <Setter Property="Foreground" Value="#324832"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="GoldBtn" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#B8902A"/>
            <Setter Property="Foreground" Value="#050C07"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Button" x:Key="GreenBtn" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#196830"/>
        </Style>
        <Style TargetType="Button" x:Key="RedBtn" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#7A1A1A"/>
        </Style>
        <Style TargetType="Button" x:Key="SlateBtn" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background" Value="#183050"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#080E09"/>
            <Setter Property="Foreground" Value="#C8D890"/>
            <Setter Property="BorderBrush" Value="#243C26"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="#B8902A"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#080E09"/>
            <Setter Property="Foreground" Value="#C8D890"/>
            <Setter Property="BorderBrush" Value="#243C26"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#080E09"/>
                        <Setter Property="Foreground" Value="#C8D890"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A3020"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#B8902A"/>
                                <Setter Property="Foreground" Value="#050C07"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#080E09"/>
            <Setter Property="RowBackground" Value="#0A1209"/>
            <Setter Property="AlternatingRowBackground" Value="#0D1610"/>
            <Setter Property="BorderBrush" Value="#152018"/>
            <Setter Property="Foreground" Value="#B8CEB0"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#121E14"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#050C07"/>
            <Setter Property="Foreground" Value="#B8902A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderBrush" Value="#1A3020"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#12221A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#162E1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#D4C070"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="275"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="215"/>
        </Grid.RowDefinitions>

       
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="#0A1409" Margin="10,10,0,10" CornerRadius="14"
                BorderThickness="1" BorderBrush="#1E3A20">

            <StackPanel Margin="20,22,20,20">

                <TextBlock Text="HIPPODROME" FontFamily="Georgia" FontSize="20"
                           FontWeight="Bold" Foreground="#C9A84C" TextAlignment="Center"/>
                <TextBlock Text="S I M U L A T O R" FontFamily="Segoe UI" FontSize="9"
                           Foreground="#3A5A3A" TextAlignment="Center" Margin="0,2,0,0"/>

                <Border Height="1" Margin="0,14,0,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#C9A84C" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                
                <Border Background="#050C07" CornerRadius="10" Padding="14,12"
                        Margin="0,0,0,22" BorderThickness="1" BorderBrush="#1A3020">
                    <StackPanel>
                        <TextBlock Text="BALANCE" FontSize="9" Foreground="#3A5A3A"
                                   FontWeight="Bold" FontFamily="Segoe UI"/>
                        <TextBlock Text="{Binding Balance, StringFormat='{}{0:F2} $'}"
                                   FontSize="30" FontWeight="Bold" FontFamily="Georgia"
                                   Foreground="#4EAA64"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="B E T S" FontSize="9" Foreground="#3A5A3A"
                           FontWeight="Bold" FontFamily="Segoe UI" Margin="2,0,0,10"/>

                <TextBlock Text="Amount" FontSize="11" Foreground="#5A7A5A"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <TextBox Text="{Binding BetAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

                <TextBlock Text="Horse" FontSize="11" Foreground="#5A7A5A"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Horses}" SelectedItem="{Binding SelectedHorse}"
                          DisplayMemberPath="Name" Margin="0,0,0,14"/>

                <Button Content="PLACE BET" Command="{Binding PlaceBetCommand}"
                        Style="{StaticResource GoldBtn}" Height="42" FontSize="14"
                        FontFamily="Georgia" Padding="0,0" Margin="0,0,0,22"/>

                <Border Height="1" Background="#182A18" Margin="0,0,0,18"/>

                <TextBlock Text="P A R T I C I P A N T S" FontSize="9" Foreground="#3A5A3A"
                           FontWeight="Bold" FontFamily="Segoe UI" Margin="2,0,0,14"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,22">
                    <Button Content="−" Command="{Binding RemoveHorseCommand}"
                            Style="{StaticResource RedBtn}" Width="36" Height="36"
                            FontSize="20" Padding="0"/>
                    <Border Background="#050C07" CornerRadius="7" Width="52" Margin="8,0"
                            BorderThickness="1" BorderBrush="#1A3020">
                        <TextBlock Text="{Binding Horses.Count}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center" FontWeight="Bold"
                                   FontSize="20" FontFamily="Georgia" Foreground="#C9A84C"/>
                    </Border>
                    <Button Content="+" Command="{Binding AddHorseCommand}"
                            Style="{StaticResource SlateBtn}" Width="36" Height="36"
                            FontSize="20" Padding="0"/>
                </StackPanel>

                <Button Content="▶   START RACE" Click="StartSimulation_Click"
                        Style="{StaticResource GreenBtn}" Height="44" FontSize="14"
                        FontFamily="Georgia" Padding="0,0" Margin="0,0,0,8"/>
                <Button Content="■   STOP" Click="StopSimulation_Click"
        IsEnabled="{Binding IsRaceRunning}"
        Style="{StaticResource RedBtn}" Height="36" FontSize="13"
        Padding="0,0" Margin="0,0,0,8"/>
                <Button Content="↺   NEW RACE" Click="ResetRace_Click"
                        IsEnabled="{Binding CanReset}"
                        Style="{StaticResource SlateBtn}" Height="36"
                        FontSize="13" Padding="0,0"/>
            </StackPanel>
        </Border>

        
        <Grid Grid.Row="0" Grid.Column="1" Margin="10,10,10,5">
            
            <Border CornerRadius="14" Background="#060C08" BorderThickness="3">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#C9A84C" Offset="0"/>
                        <GradientStop Color="#423415" Offset="0.5"/>
                        <GradientStop Color="#C9A84C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

               
                <Border Margin="5" CornerRadius="10" ClipToBounds="True" Background="#0F2414"
                        BorderThickness="1" BorderBrush="#18361E">
                    <Grid>
                        
                        <Image x:Name="RenderImage" Stretch="Fill"/>

                        <Border CornerRadius="10" BorderThickness="5" IsHitTestVisible="False">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#60000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="0.15"/>
                                    <GradientStop Color="#00000000" Offset="0.85"/>
                                    <GradientStop Color="#60000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                        </Border>
                    </Grid>
                </Border>
            </Border>

            <Border CornerRadius="14"
                    Visibility="{Binding IsRaceFinished, Converter={StaticResource BoolToVis}}">
                <Border.Background>
                    <SolidColorBrush Color="#E6060C08"/>
                </Border.Background>
                <Grid>
                    <Border VerticalAlignment="Top" Height="3" CornerRadius="12,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#C9A84C" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding ResultTitle}"
                                   FontFamily="Georgia" FontSize="36" FontWeight="Bold"
                                   Foreground="#C9A84C" TextAlignment="Center"/>
                        <TextBlock Text="{Binding ResultSubtitle}"
                                   FontFamily="Segoe UI" FontSize="18"
                                   Foreground="#90C8A0" TextAlignment="Center" Margin="0,8,0,0"/>
                        <Button Content="↺   NEW RACE" Click="ResetRace_Click"
                                Style="{StaticResource GoldBtn}" Width="230" Height="48"
                                FontSize="16" FontFamily="Georgia" Margin="0,34,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1"
                Background="#0A1409" Margin="10,5,10,10" CornerRadius="12"
                BorderThickness="1" BorderBrush="#1A3020">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="L E A D E R B O A R D"
                           FontFamily="Georgia" FontSize="10" FontWeight="Bold"
                           Foreground="#C9A84C" Margin="16,10,0,8"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Horses}" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column"
                          SelectionMode="Single" BorderThickness="0" Margin="0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="COLOR" Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ChangeHorseColorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Click to change colour">
                                        <Rectangle Width="22" Height="22" RadiusX="5" RadiusY="5">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="{Binding HorseColor}"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="PLACE"    Binding="{Binding Place}"                                        Width="0.5*"/>
                        <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"                                         Width="2*"/>
                        <DataGridTextColumn Header="TIME"     Binding="{Binding RaceTime, StringFormat={}{0:mm\\:ss\\.ff}}"   Width="*"/>
                        <DataGridTextColumn Header="COEF"     Binding="{Binding Coefficient, StringFormat={}{0:F2}}"           Width="*"/>
                        <DataGridTextColumn Header="BET"      Binding="{Binding MoneyBet, StringFormat={}{0:F2} $}"            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>